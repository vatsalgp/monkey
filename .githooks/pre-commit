#!/usr/bin/env bash
set -euo pipefail

# Format only staged Go files that are part of this commit.
go_files="$(git diff --cached --name-only --diff-filter=ACMR -- '*.go')"

if [ -z "$go_files" ]; then
  exit 0
fi

printf '%s\n' "$go_files" | xargs gofmt -w
printf '%s\n' "$go_files" | xargs git add --
